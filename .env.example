# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lagaitana

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# MercadoPago
# Obtén tus credenciales en: https://www.mercadopago.com/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=APP_USR-YOUR_ACCESS_TOKEN_HERE
MERCADOPAGO_PUBLIC_KEY=APP_USR-YOUR_PUBLIC_KEY_HERE

# Frontend URL (para CORS y redirects de pago)
FRONTEND_URL=http://localhost:8080
